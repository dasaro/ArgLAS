\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Median ILASP training time (log colour scale; darker $=$ slower), same axes as Figure~\ref {fig:recovery_heatmap}. Clean cells cost seconds (bright); adding noise darkens the surface by \emph  {orders of magnitude} --- up to $\sim $$570$\,s at the top-right --- so the cost frontier and the accuracy frontier are driven by the same noise axis. Cells that exceeded the $3{,}500$\,s cap are excluded from the median (Section~\ref {sec:exp1cost}).}}{33}{figure.12}\protected@file@percent }
\newlabel{fig:time_heatmap}{{12}{33}{Median ILASP training time (log colour scale; darker $=$ slower), same axes as Figure~\ref {fig:recovery_heatmap}. Clean cells cost seconds (bright); adding noise darkens the surface by \emph {orders of magnitude} --- up to $\sim $$570$\,s at the top-right --- so the cost frontier and the accuracy frontier are driven by the same noise axis. Cells that exceeded the $3{,}500$\,s cap are excluded from the median (Section~\ref {sec:exp1cost})}{figure.12}{}}
\def\@LN@column{1}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Generator breadth at $f=60$: recovery on the dense pool vs.\ sparse, self-attacking, and larger ($n{\le }12$) frameworks, clean (left) and noisy (right); bars are means over label completeness $\{1.0,0.5\}$ and five folds, with $\pm 1$ s.e.m. Clean recovery reproduces across all generators; under noise, sparse and larger frameworks stay high (larger with heavier timeout censoring, $25/160$), while \emph  {preferred on self-attacking frameworks} is the one regime that degrades --- a mechanistically explained boundary, not an artifact.}}{34}{figure.13}\protected@file@percent }
\newlabel{fig:generator_breadth}{{13}{34}{Generator breadth at $f=60$: recovery on the dense pool vs.\ sparse, self-attacking, and larger ($n{\le }12$) frameworks, clean (left) and noisy (right); bars are means over label completeness $\{1.0,0.5\}$ and five folds, with $\pm 1$ s.e.m. Clean recovery reproduces across all generators; under noise, sparse and larger frameworks stay high (larger with heavier timeout censoring, $25/160$), while \emph {preferred on self-attacking frameworks} is the one regime that degrades --- a mechanistically explained boundary, not an artifact}{figure.13}{}}
