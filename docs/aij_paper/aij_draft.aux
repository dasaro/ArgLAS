\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces The completeness--noise interaction: mean recovery by label completeness $p$ and noise $q$ (balanced arm, pooled over semantics and $f$; $n$ = completed runs of $120$ per cell). Incompleteness alone is free --- recovery at $q{=}0$ is flat-to-rising as $p$ falls --- but it amplifies noise: at $q{=}0.2$ the drop from $p{=}1.0$ to $p{=}0.5$ is $0.25$ MCC, on the surviving runs of a cell that also loses a third of its runs to timeouts.}}{26}{table.2}\protected@file@percent }
\newlabel{tab:pq}{{2}{26}{The completeness--noise interaction: mean recovery by label completeness $p$ and noise $q$ (balanced arm, pooled over semantics and $f$; $n$ = completed runs of $120$ per cell). Incompleteness alone is free --- recovery at $q{=}0$ is flat-to-rising as $p$ falls --- but it amplifies noise: at $q{=}0.2$ the drop from $p{=}1.0$ to $p{=}0.5$ is $0.25$ MCC, on the surviving runs of a cell that also loses a third of its runs to timeouts}{table.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Class imbalance: mean recovery per positive-fraction arm over the cells present in all three arms (matched on semantics, completeness, noise, and total training size; $52$--$54$ matched cells per semantics --- matching requires at least one completed run per arm).}}{26}{table.3}\protected@file@percent }
\newlabel{tab:imbalance}{{3}{26}{Class imbalance: mean recovery per positive-fraction arm over the cells present in all three arms (matched on semantics, completeness, noise, and total training size; $52$--$54$ matched cells per semantics --- matching requires at least one completed run per arm)}{table.3}{}}
\def\@LN@column{1}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces The completeness--noise interaction (Table~\ref {tab:pq}) as a heatmap. The top row (clean labels) is uniformly bright regardless of completeness; the bottom-right cell (half the labels missing \emph  {and} noisy) is the only dark one --- incompleteness is free alone but multiplies the cost of noise.}}{27}{figure.7}\protected@file@percent }
\newlabel{fig:pq}{{7}{27}{The completeness--noise interaction (Table~\ref {tab:pq}) as a heatmap. The top row (clean labels) is uniformly bright regardless of completeness; the bottom-right cell (half the labels missing \emph {and} noisy) is the only dark one --- incompleteness is free alone but multiplies the cost of noise}{figure.7}{}}
