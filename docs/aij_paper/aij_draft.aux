\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Recovery (mean MCC on the complete-information surface) by semantics, label noise $q$, and examples per class $f$; balanced ($50\%$-positive) arm, pooled over label completeness --- up to $15$ runs per cell ($3$ completeness levels $\times $ $5$ folds; failed runs, all timeouts, excluded --- Section~\ref {sec:exp1cost} quantifies the exclusions). Per-cell $95\%$ t-corrected CI half-widths never exceed $0.053$ at $q{=}0$, $0.184$ at $q{=}0.1$, and $0.205$ at $q{=}0.2$ (shown as bands in Figure~\ref {fig:recovery_curves}); full per-cell tables with standard deviations are in \ref {app:campaign}.}}{68}{table.1}\protected@file@percent }
\newlabel{tab:surface}{{1}{68}{Recovery (mean MCC on the complete-information surface) by semantics, label noise $q$, and examples per class $f$; balanced ($50\%$-positive) arm, pooled over label completeness --- up to $15$ runs per cell ($3$ completeness levels $\times $ $5$ folds; failed runs, all timeouts, excluded --- Section~\ref {sec:exp1cost} quantifies the exclusions). Per-cell $95\%$ t-corrected CI half-widths never exceed $0.053$ at $q{=}0$, $0.184$ at $q{=}0.1$, and $0.205$ at $q{=}0.2$ (shown as bands in Figure~\ref {fig:recovery_curves}); full per-cell tables with standard deviations are in \ref {app:campaign}}{table.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces The completeness--noise interaction: mean recovery by label completeness $p$ and noise $q$ (balanced arm, pooled over semantics and $f$; $n$ = completed runs of $120$ per cell). Incompleteness alone is free --- recovery at $q{=}0$ is flat-to-rising as $p$ falls --- but it amplifies noise: at $q{=}0.2$ the drop from $p{=}1.0$ to $p{=}0.5$ is $0.25$ MCC, on the surviving runs of a cell that also loses a third of its runs to timeouts.}}{69}{table.2}\protected@file@percent }
\newlabel{tab:pq}{{2}{69}{The completeness--noise interaction: mean recovery by label completeness $p$ and noise $q$ (balanced arm, pooled over semantics and $f$; $n$ = completed runs of $120$ per cell). Incompleteness alone is free --- recovery at $q{=}0$ is flat-to-rising as $p$ falls --- but it amplifies noise: at $q{=}0.2$ the drop from $p{=}1.0$ to $p{=}0.5$ is $0.25$ MCC, on the surviving runs of a cell that also loses a third of its runs to timeouts}{table.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Class imbalance: mean recovery per positive-fraction arm over the cells present in all three arms (matched on semantics, completeness, noise, and total training size; $52$--$54$ matched cells per semantics --- matching requires at least one completed run per arm).}}{69}{table.3}\protected@file@percent }
\newlabel{tab:imbalance}{{3}{69}{Class imbalance: mean recovery per positive-fraction arm over the cells present in all three arms (matched on semantics, completeness, noise, and total training size; $52$--$54$ matched cells per semantics --- matching requires at least one completed run per arm)}{table.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Framework breadth (label completeness $1.0$, no noise, $5$ folds; mean MCC with worst fold in parentheses). Left: BAF cells, learned with the unchanged AAF mode bias over $B_{\mathrm  {BAF}}$ ($80$ test instances per class). Right: cells on ABA-translated AAFs via the corrected translation ($15$ test instances per class --- over half of random flat ABAs have no stable extension, capping the per-fold test yield).}}{70}{table.4}\protected@file@percent }
\newlabel{tab:breadth}{{4}{70}{Framework breadth (label completeness $1.0$, no noise, $5$ folds; mean MCC with worst fold in parentheses). Left: BAF cells, learned with the unchanged AAF mode bias over $B_{\mathrm {BAF}}$ ($80$ test instances per class). Right: cells on ABA-translated AAFs via the corrected translation ($15$ test instances per class --- over half of random flat ABAs have no stable extension, capping the per-fold test yield)}{table.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Experiment 2: apples-to-apples comparison on the individual-graph pool ($n{=}495$). ``Skept.'' is three-valued exact match under the skeptical reading (chance $33.3\%$); ``\textsc  {co}{}'' is committed-only accuracy under the credulous reading. Learned theories are agnostic (no target semantics); learner rows use the pipeline's canonical fold seed ($20260703$, fixed at run time --- the most learner-favourable of the four seeds later used in Table~\ref {tab:aux}, which makes the learner-below-CF2 conclusion conservative). The ILASP row inherits the arity-one expressivity caveat flagged by the stable gate (Section~\ref {sec:bridge}, B1). Point accuracies are descriptive --- $95\%$ binomial half-widths are at most $\pm 0.044$ on the skeptical columns ($n{=}495$) and $\pm 0.056$ on the committed columns ($n{=}310$) --- and all learner-versus-CF2 conclusions rest on the paired McNemar tests reported in the text. Best learner and best overall per column in \textbf  {bold}.}}{71}{table.5}\protected@file@percent }
\newlabel{tab:act1}{{5}{71}{Experiment 2: apples-to-apples comparison on the individual-graph pool ($n{=}495$). ``Skept.'' is three-valued exact match under the skeptical reading (chance $33.3\%$); ``\co {}'' is committed-only accuracy under the credulous reading. Learned theories are agnostic (no target semantics); learner rows use the pipeline's canonical fold seed ($20260703$, fixed at run time --- the most learner-favourable of the four seeds later used in Table~\ref {tab:aux}, which makes the learner-below-CF2 conclusion conservative). The ILASP row inherits the arity-one expressivity caveat flagged by the stable gate (Section~\ref {sec:bridge}, B1). Point accuracies are descriptive --- $95\%$ binomial half-widths are at most $\pm 0.044$ on the skeptical columns ($n{=}495$) and $\pm 0.056$ on the committed columns ($n{=}310$) --- and all learner-versus-CF2 conclusions rest on the paired McNemar tests reported in the text. Best learner and best overall per column in \best {bold}}{table.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Experiment 2, contextual-reasoning test (committed-only accuracy, \emph  {final} pool, auxiliary vocabulary).}}{72}{table.6}\protected@file@percent }
\newlabel{tab:act3}{{6}{72}{Experiment 2, contextual-reasoning test (committed-only accuracy, \emph {final} pool, auxiliary vocabulary)}{table.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Auxiliary-predicate gain: committed-only accuracy (\emph  {final} pool), paired across four cross-validation seeds. Baseline $=$ FastLAS OPL, primitive features; CF2 $= 0.797$. Seed $20260703$ (first column) is the canonical seed used throughout Section~\ref {sec:act1}; Table~\ref {tab:act1}'s $0.594$ is that seed's baseline value.}}{72}{table.7}\protected@file@percent }
\newlabel{tab:aux}{{7}{72}{Auxiliary-predicate gain: committed-only accuracy (\emph {final} pool), paired across four cross-validation seeds. Baseline $=$ FastLAS OPL, primitive features; CF2 $= 0.797$. Seed $20260703$ (first column) is the canonical seed used throughout Section~\ref {sec:act1}; Table~\ref {tab:act1}'s $0.594$ is that seed's baseline value}{table.7}{}}
