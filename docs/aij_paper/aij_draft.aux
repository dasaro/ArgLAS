\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces The recovery surface of Table~\ref {tab:surface} as a heatmap (brighter $=$ better recovery). At clean labels ($q=0$) recovery is near-perfect from $f\ge 30$; noise darkens the surface, and the damage is concentrated at small $f$ and worst for admissible/complete --- but every semantics recovers to the bright band as $f$ grows.}}{23}{figure.5}\protected@file@percent }
\newlabel{fig:recovery_heatmap}{{5}{23}{The recovery surface of Table~\ref {tab:surface} as a heatmap (brighter $=$ better recovery). At clean labels ($q=0$) recovery is near-perfect from $f\ge 30$; noise darkens the surface, and the damage is concentrated at small $f$ and worst for admissible/complete --- but every semantics recovers to the bright band as $f$ grows}{figure.5}{}}
\def\@LN@column{1}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Recovery surfaces}{23}{subsection.5.2}\protected@file@percent }
\newlabel{sec:exp1surfaces}{{5.2}{23}{Recovery surfaces}{subsection.5.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces The same surface as recovery-vs-sample-size curves, one line per semantics; shaded bands are $95\%$ t-corrected CIs over the completed runs per cell. The ``noise is bought back by data'' effect (E1.2) is the upward slope in the $q=0.2$ panel: recovery rises from $0.48$--$0.74$ at $f=10$ to $0.94$--$0.96$ at $f=80$, with no plateau below clean performance.}}{24}{figure.6}\protected@file@percent }
\newlabel{fig:recovery_curves}{{6}{24}{The same surface as recovery-vs-sample-size curves, one line per semantics; shaded bands are $95\%$ t-corrected CIs over the completed runs per cell. The ``noise is bought back by data'' effect (E1.2) is the upward slope in the $q=0.2$ panel: recovery rises from $0.48$--$0.74$ at $f=10$ to $0.94$--$0.96$ at $f=80$, with no plateau below clean performance}{figure.6}{}}
\def\@LN@column{1}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces The completeness--noise interaction (Table~\ref {tab:pq}) as a heatmap. The top row (clean labels) is uniformly bright regardless of completeness; the bottom-right cell (half the labels missing \emph  {and} noisy) is the only dark one --- incompleteness is free alone but multiplies the cost of noise.}}{25}{figure.7}\protected@file@percent }
\newlabel{fig:pq}{{7}{25}{The completeness--noise interaction (Table~\ref {tab:pq}) as a heatmap. The top row (clean labels) is uniformly bright regardless of completeness; the bottom-right cell (half the labels missing \emph {and} noisy) is the only dark one --- incompleteness is free alone but multiplies the cost of noise}{figure.7}{}}
\def\@LN@column{1}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Recovery versus label noise at a fixed, fully-complete sample size ($f=20$, balanced arm), with full labels ($p=1.0$, left) and half labels ($p=0.5$, right). Error bars are $95\%$ confidence intervals over the five cross-validation folds (clipped to the valid MCC range). Partial labels turn a gentle, low-variance noise response into a steep, high-variance one --- the same noise is far more damaging when labels are also incomplete.}}{26}{figure.8}\protected@file@percent }
\newlabel{fig:slice_noise}{{8}{26}{Recovery versus label noise at a fixed, fully-complete sample size ($f=20$, balanced arm), with full labels ($p=1.0$, left) and half labels ($p=0.5$, right). Error bars are $95\%$ confidence intervals over the five cross-validation folds (clipped to the valid MCC range). Partial labels turn a gentle, low-variance noise response into a steep, high-variance one --- the same noise is far more damaging when labels are also incomplete}{figure.8}{}}
\def\@LN@column{1}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Recovery versus label completeness at fixed $f=20$ (balanced arm), on clean labels ($q=0$, left) and noisy labels ($q=0.2$, right); $95\%$ fold-level confidence intervals. Completeness is almost irrelevant when labels are clean (flat lines, tight intervals) but costly and variance-inflating once noise is present --- the interaction of Table~\ref {tab:pq} resolved per semantics.}}{27}{figure.9}\protected@file@percent }
\newlabel{fig:slice_partial}{{9}{27}{Recovery versus label completeness at fixed $f=20$ (balanced arm), on clean labels ($q=0$, left) and noisy labels ($q=0.2$, right); $95\%$ fold-level confidence intervals. Completeness is almost irrelevant when labels are clean (flat lines, tight intervals) but costly and variance-inflating once noise is present --- the interaction of Table~\ref {tab:pq} resolved per semantics}{figure.9}{}}
