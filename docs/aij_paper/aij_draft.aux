\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces $B_{\mathrm  {BAF}}$: transitive support closure and support-extended defeat (supported and indirect attacks), replacing the first rule of Figure~\ref {fig:bg}. The BAF background additionally redefines \textsf  {supported}$/1$ in the bipolar sense (``supported by an accepted argument''). The fixed encodings of Figure~\ref {fig:learned} and the programs of Section~\ref {sec:mech} never mention \textsf  {supported}, so the two readings affect no correctness theorem; campaign-learned hypotheses may (and do) use \textsf  {supported}, each under its own family's reading, and the two readings never co-occur in one learning task.}}{11}{figure.3}\protected@file@percent }
\newlabel{fig:bgbaf}{{3}{11}{$B_{\mathrm {BAF}}$: transitive support closure and support-extended defeat (supported and indirect attacks), replacing the first rule of Figure~\ref {fig:bg}. The BAF background additionally redefines \pred {supported}$/1$ in the bipolar sense (``supported by an accepted argument''). The fixed encodings of Figure~\ref {fig:learned} and the programs of Section~\ref {sec:mech} never mention \pred {supported}, so the two readings affect no correctness theorem; campaign-learned hypotheses may (and do) use \pred {supported}, each under its own family's reading, and the two readings never co-occur in one learning task}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces The learned encodings, as induced by ILASP from curated labelled frameworks. Section~\ref {sec:mech} proves the stable/admissible/complete rows equivalent to their ASPARTIX references over the definitional context $D_{\mathrm  {AAF}}$ (Theorem~\ref {thm:aaf}) and the preferred construction correct on every framework (Theorem~\ref {thm:prf}). Under the sampled-data campaign of Section~\ref {sec:exp1} the learner typically returns \emph  {constraint-style} presentations of the same semantics over the guessing background (Section~\ref {sec:exp1surfaces}).}}{12}{figure.4}\protected@file@percent }
\newlabel{fig:learned}{{4}{12}{The learned encodings, as induced by ILASP from curated labelled frameworks. Section~\ref {sec:mech} proves the stable/admissible/complete rows equivalent to their ASPARTIX references over the definitional context $\Daaf $ (Theorem~\ref {thm:aaf}) and the preferred construction correct on every framework (Theorem~\ref {thm:prf}). Under the sampled-data campaign of Section~\ref {sec:exp1} the learner typically returns \emph {constraint-style} presentations of the same semantics over the guessing background (Section~\ref {sec:exp1surfaces})}{figure.4}{}}
