\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Recovery (mean MCC on the complete-information surface) by semantics, label noise $q$, and examples per class $f$; balanced ($50\%$-positive) arm, pooled over label completeness --- up to $15$ runs per cell ($3$ completeness levels $\times $ $5$ folds; failed runs, all timeouts, excluded --- Section~\ref {sec:exp1cost} quantifies the exclusions). Per-cell $95\%$ t-corrected CI half-widths never exceed $0.053$ at $q{=}0$, $0.184$ at $q{=}0.1$, and $0.205$ at $q{=}0.2$ (shown as bands in Figure~\ref {fig:recovery_curves}); full per-cell tables with standard deviations are in \ref {app:campaign}.}}{80}{table.1}\protected@file@percent }
\newlabel{tab:surface}{{1}{80}{Recovery (mean MCC on the complete-information surface) by semantics, label noise $q$, and examples per class $f$; balanced ($50\%$-positive) arm, pooled over label completeness --- up to $15$ runs per cell ($3$ completeness levels $\times $ $5$ folds; failed runs, all timeouts, excluded --- Section~\ref {sec:exp1cost} quantifies the exclusions). Per-cell $95\%$ t-corrected CI half-widths never exceed $0.053$ at $q{=}0$, $0.184$ at $q{=}0.1$, and $0.205$ at $q{=}0.2$ (shown as bands in Figure~\ref {fig:recovery_curves}); full per-cell tables with standard deviations are in \ref {app:campaign}}{table.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces The completeness--noise interaction: mean recovery by label completeness $p$ and noise $q$ (balanced arm, pooled over semantics and $f$; $n$ = completed runs of $120$ per cell). Incompleteness alone is free --- recovery at $q{=}0$ is flat-to-rising as $p$ falls --- but it amplifies noise: at $q{=}0.2$ the drop from $p{=}1.0$ to $p{=}0.5$ is $0.25$ MCC, on the surviving runs of a cell that also loses a third of its runs to timeouts.}}{81}{table.2}\protected@file@percent }
\newlabel{tab:pq}{{2}{81}{The completeness--noise interaction: mean recovery by label completeness $p$ and noise $q$ (balanced arm, pooled over semantics and $f$; $n$ = completed runs of $120$ per cell). Incompleteness alone is free --- recovery at $q{=}0$ is flat-to-rising as $p$ falls --- but it amplifies noise: at $q{=}0.2$ the drop from $p{=}1.0$ to $p{=}0.5$ is $0.25$ MCC, on the surviving runs of a cell that also loses a third of its runs to timeouts}{table.2}{}}
