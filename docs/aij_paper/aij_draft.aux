\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces The same surface as recovery-vs-sample-size curves, one line per semantics; shaded bands are $95\%$ t-corrected CIs over the completed runs per cell. The ``noise is bought back by data'' effect (E1.2) is the upward slope in the $q=0.2$ panel: recovery rises from $0.48$--$0.74$ at $f=10$ to $0.94$--$0.96$ at $f=80$, with no plateau below clean performance.}}{27}{figure.7}\protected@file@percent }
\newlabel{fig:recovery_curves}{{7}{27}{The same surface as recovery-vs-sample-size curves, one line per semantics; shaded bands are $95\%$ t-corrected CIs over the completed runs per cell. The ``noise is bought back by data'' effect (E1.2) is the upward slope in the $q=0.2$ panel: recovery rises from $0.48$--$0.74$ at $f=10$ to $0.94$--$0.96$ at $f=80$, with no plateau below clean performance}{figure.7}{}}
\def\@LN@column{1}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces The completeness--noise interaction (Table~\ref {tab:pq}) as a heatmap. The top row (clean labels) is uniformly bright regardless of completeness; the bottom-right cell (half the labels missing \emph  {and} noisy) is the only dark one --- incompleteness is free alone but multiplies the cost of noise.}}{28}{figure.8}\protected@file@percent }
\newlabel{fig:pq}{{8}{28}{The completeness--noise interaction (Table~\ref {tab:pq}) as a heatmap. The top row (clean labels) is uniformly bright regardless of completeness; the bottom-right cell (half the labels missing \emph {and} noisy) is the only dark one --- incompleteness is free alone but multiplies the cost of noise}{figure.8}{}}
